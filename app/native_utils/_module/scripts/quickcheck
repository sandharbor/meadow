#!/bin/bash

echo "🧪 Running native_utils checks in parallel..."

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

check_subdir() {
    local dir="$1"
    local name="$2"
    (
        cd "$SCRIPT_DIR/$dir"
        echo "📦 Checking $name..."
        ./_module/scripts/quickcheck
        if [ $? -ne 0 ]; then
            echo "❌ $name check failed."
            exit 1
        else
            echo "✅ $name checks passed"
        fi
    )
}

# Run all checks in parallel — capture PIDs explicitly (jobs -p is unreliable)
pids=()
check_subdir "source_page_search_by_title" "source_page_search_by_title" & pids+=($!)
check_subdir "fast_git_ops" "fast_git_ops" & pids+=($!)
check_subdir "working_graph" "working_graph" & pids+=($!)

# Wait for all background jobs to complete
exit_code=0
for pid in "${pids[@]}"; do
    if ! wait "$pid"; then
        exit_code=1
    fi
done

if [ $exit_code -ne 0 ]; then
    echo "❌ One or more native_utils checks failed"
    exit 1
fi

echo "✅ All native_utils checks passed!"

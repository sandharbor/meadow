#!/bin/bash
set -euo pipefail
cd "$(dirname "$0")/../.."

stamp="node_modules/.quickcheck_install_stamp"
if [ ! -f "$stamp" ] || [ ! -d "node_modules" ] || [ "package-lock.json" -nt "$stamp" ]; then
    npm install --force 2>&1
    touch "$stamp"
fi

echo "Running test-runner type checking..."
npx tsc --noEmit --project tsconfig.json
echo "Type checking passed."

echo "Linting final-assertion placement in specs..."
npx tsx _module/scripts/lint-final-assertion.ts

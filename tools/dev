#!/usr/bin/env bash
#
# Start all dev servers (backend, frontend, dev-tools) in a tmux session.
# - Worktrees: allocate random ports in a per-run tmpdir (parallel-safe).
# - Main repo: reuse whatever ports are set in the real Meadow home; don't
#   allocate random ones (so VS Code tasks and tools/dev stay in sync).
# Re-running kills and recreates the session.
#
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
BACKEND_DIR="$REPO_ROOT/app/backend"
FRONTEND_DIR="$REPO_ROOT/app/frontend"
DEV_TOOLS_DIR="$REPO_ROOT/app/dev_tools_app"

# --- 1. Derive worktree name from directory basename ---
BASENAME="$(basename "$REPO_ROOT")"
IS_MAIN_REPO=false
if [[ "$BASENAME" =~ ^meadow_wt_(.+)$ ]]; then
  WORKTREE_NAME="${BASH_REMATCH[1]}"
elif [[ "$BASENAME" =~ ^meadow_work_(.+)$ ]]; then
  WORKTREE_NAME="${BASH_REMATCH[1]}"
elif [[ "$BASENAME" == "meadow" ]]; then
  WORKTREE_NAME="main"
  IS_MAIN_REPO=true
else
  WORKTREE_NAME="$BASENAME"
fi

SESSION="meadow_dev_${WORKTREE_NAME}"

# --- 2. Kill existing session if present ---
if tmux has-session -t "$SESSION" 2>/dev/null; then
  echo "Killing existing session '$SESSION'..."
  tmux kill-session -t "$SESSION"
fi

# --- 3. Resolve config dir & ports ---
if [ "$IS_MAIN_REPO" = true ]; then
  echo "Main repo detected: using the real Meadow home; not allocating random ports."
  CONFIG_DIR=$(cd "$BACKEND_DIR" && npx tsx src/scripts/resolve_main_repo_config_dir.ts)
else
  echo "Setting up worktree resources config..."
  CONFIG_DIR=$(cd "$BACKEND_DIR" && npx tsx src/scripts/setup_worktree_resources_config.ts)
fi
echo "Config directory: $CONFIG_DIR"

# --- 4. Read ports from resources.yaml and resources.local.yaml ---
RESOURCES_YAML="$CONFIG_DIR/app/resources.yaml"
RESOURCES_LOCAL="$CONFIG_DIR/app/resources.local.yaml"

get_port() {
  local key=$1
  local default=$2
  local value=""
  if [ -f "$RESOURCES_LOCAL" ]; then
    value=$(grep "^$key:" "$RESOURCES_LOCAL" 2>/dev/null | head -1 | awk '{print $2}' || true)
  fi
  if [ -z "$value" ] && [ -f "$RESOURCES_YAML" ]; then
    value=$(grep "^$key:" "$RESOURCES_YAML" 2>/dev/null | head -1 | awk '{print $2}' || true)
  fi
  echo "${value:-$default}"
}

BACKEND_PORT=$(get_port backendPort "")
FRONTEND_PORT=$(get_port frontendPort "")
DEV_TOOLS_PORT=$(get_port devToolsPort 5174)
DEV_TOOLS_SERVER_PORT=$(get_port devToolsServerPort 3002)

if [ -z "$BACKEND_PORT" ] || [ -z "$FRONTEND_PORT" ]; then
  echo "Error: backendPort and frontendPort must be set in $RESOURCES_YAML or $RESOURCES_LOCAL" >&2
  exit 1
fi

# --- 5. Create tmux session with 3 windows ---
tmux new-session -d -s "$SESSION" -n backend -c "$BACKEND_DIR" \
  "MEADOW_IS_DEV='true' MEADOW_HOME_DIRECTORY_OVERRIDE='$CONFIG_DIR' npx tsx src/index.ts; read"

tmux new-window -t "$SESSION" -n frontend -c "$FRONTEND_DIR" \
  "VITE_FRONTEND_PORT='$FRONTEND_PORT' VITE_BACKEND_PORT='$BACKEND_PORT' npx vite; read"

tmux new-window -t "$SESSION" -n dev-tools -c "$DEV_TOOLS_DIR" \
  "PORT='$DEV_TOOLS_SERVER_PORT' VITE_DEV_TOOLS_CLIENT_PORT='$DEV_TOOLS_PORT' MEADOW_HOME_DIRECTORY_OVERRIDE='$CONFIG_DIR' npm start; read"

# --- 6. Wait for frontend to be ready, then open browser ---
echo "Waiting for frontend (http://localhost:$FRONTEND_PORT)..."
for i in $(seq 1 60); do
  if curl -s -o /dev/null -w '' "http://localhost:$FRONTEND_PORT" 2>/dev/null; then
    echo "Frontend is ready."
    open "http://localhost:$DEV_TOOLS_PORT"
    break
  fi
  if [ "$i" -eq 60 ]; then
    echo "Warning: Frontend did not respond within 30s. Opening anyway..."
    open "http://localhost:$DEV_TOOLS_PORT"
  fi
  sleep 0.5
done

# --- 7. Print summary ---
echo ""
echo "======================================"
echo "  Meadow dev servers running [$WORKTREE_NAME]"
echo ""
echo "  Backend:   http://localhost:$BACKEND_PORT"
echo "  Frontend:  http://localhost:$FRONTEND_PORT"
echo "  Dev Tools: http://localhost:$DEV_TOOLS_PORT"
echo "  Config:    $CONFIG_DIR"
echo ""
echo "  Attach: tmux attach -t $SESSION"
echo "  Kill:   tmux kill-session -t $SESSION"
echo "======================================"

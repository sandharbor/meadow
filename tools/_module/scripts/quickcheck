#!/bin/bash

# Check for required directories and files in tools/
REQUIRED_DIRS=(
    "mw-cli"
)
REQUIRED_FILES=(
)
OK_FILES=(".DS_Store" "apply-copyright" "dev" "sim_meadow_cloud_extraction" "stress_test" "test_in_worktree" "run_agent_task.sh" ".gitignore")
OK_DIRS=("afk" "agent_task" "logs" "_module" "verify_extended_syntax")

echo_and_exit() {
    echo "$1"
    exit 1
}

for dir in "${REQUIRED_DIRS[@]}"; do
    if [ ! -d "$dir" ]; then
        echo_and_exit "❌ Required directory '$dir' is missing."
    fi
done

for file in "${REQUIRED_FILES[@]}"; do
    if [ ! -f "$file" ]; then
        echo_and_exit "❌ Required file '$file' is missing."
    fi
done

for entry in * .[^.]*; do
    # Skip . and .. and literal glob pattern when no matches
    [ "$entry" = "." ] && continue
    [ "$entry" = ".." ] && continue
    [ "$entry" = '.[^.]*' ] && continue
    [ ! -e "$entry" ] && continue
    is_ok=false
    for dir in "${REQUIRED_DIRS[@]}"; do
        if [ "$entry" = "$dir" ]; then
            is_ok=true
            break
        fi
    done
    for file in "${REQUIRED_FILES[@]}"; do
        if [ "$entry" = "$file" ]; then
            is_ok=true
            break
        fi
    done
    for file in "${OK_FILES[@]}"; do
        if [ "$entry" = "$file" ]; then
            is_ok=true
            break
        fi
    done
    for dir in "${OK_DIRS[@]}"; do
        if [ "$entry" = "$dir" ]; then
            is_ok=true
            break
        fi
    done
    if [ "$is_ok" = false ]; then
        echo_and_exit "❌ Extraneous file or directory found in tools/: $entry. Should have been moved or deleted."
    fi
done

function check_dir() {
    local dir="$1"
    if [ ! -d "$dir" ]; then
        echo_and_exit "❌ Required directory '$dir' is missing."
    fi

    if [ ! -f "$dir/_module/scripts/quickcheck" ]; then
        echo_and_exit "❌ _module/scripts/quickcheck not found at $dir."
    fi

    (
        cd "$dir"
        echo "🔍 Checking $dir..."
        ./_module/scripts/quickcheck
        if [ $? -ne 0 ]; then
            echo "❌ check failed for $dir"
            exit 1
        else
            echo "✅ $dir checks passed"
        fi
    )
}

check_dir "mw-cli" || exit 1

echo "✅ All tools checks passed!"
